{
  "compilerOptions": {
    "baseUrl": "src",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["*"],
      "@assets/*": ["assets/*"],
      "@api/*": ["api/*"],
      "@/views/*": ["views/*"],
      "@viewmodels/*": ["viewmodels/*"],
      "@models/*": ["models/*"],
      "@routers/*": ["routers/*"],
      "@components/*": ["components/*"],
      "@layouts/*": ["views/layouts/*"],
      "@pages/*": ["views/pages/*"]
    }
  },
  "include": ["src"]
}
